* { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', sans-serif; }

body { background-color: #000; color: #fff; overflow: hidden; }

.screen { display: none; height: 100vh; width: 100vw; }
.screen.active { display: flex; flex-direction: column; }

/* Auth & Profile Styles */
.auth-container { padding: 40px; display: flex; flex-direction: column; gap: 20px; align-items: center; justify-content: center; height: 100%; }
.logo-k { color: #8a2be2; font-size: 4rem; font-weight: bold; }
.logo-k span { color: #fff; }
.tabs button { background: none; border: none; color: #555; font-size: 1.2rem; margin: 0 10px; cursor: pointer; }
.tabs button.active { color: #fff; border-bottom: 2px solid #8a2be2; }
input { background: #1a1a1a; border: 1px solid #333; padding: 12px; border-radius: 8px; color: #fff; width: 100%; }
button { background: #8a2be2; color: #fff; border: none; padding: 12px 30px; border-radius: 25px; cursor: pointer; }

/* Estilo idêntico à foto */
.top-bar { display: flex; align-items: center; padding: 15px; gap: 15px; }
.logo-small { color: #8a2be2; font-weight: bold; font-size: 24px; }
.search-container { background: #121212; flex: 1; display: flex; align-items: center; padding: 8px 15px; border-radius: 12px; border: 1px solid #222; }
.search-container i { color: #888; margin-right: 10px; }
.search-container input { background: transparent; border: none; outline: none; padding: 0; }

.feed-header { display: flex; justify-content: space-between; align-items: center; padding: 20px; }
.feed-header h1 { font-size: 28px; font-weight: bold; }
.refresh-icon { color: #8a2be2; font-size: 20px; }

/* Bottom Nav */
.bottom-nav { position: fixed; bottom: 20px; width: 100%; display: flex; justify-content: center; }
.nav-container { background: #0a0a0a; width: 90%; height: 70px; border-radius: 35px; border: 1px solid #1a1a1a; display: flex; justify-content: space-around; align-items: center; position: relative; }
.nav-item { font-size: 24px; color: #888; }
.active-nav { color: #fff; }
.plus-btn { 
    background: linear-gradient(45deg, #c026d3, #db2777); 
    width: 60px; height: 60px; border-radius: 20px; 
    display: flex; align-items: center; justify-content: center;
    font-size: 24px; margin-top: -10px; box-shadow: 0 0 15px rgba(192, 38, 211, 0.4);
}
